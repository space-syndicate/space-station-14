action-malf-hack-apc-name = Hack APC
action-malf-hack-apc-description = Forces the APC's breaker off and dumps half of its battery. Costs 25 processing power.

action-malf-overload-machine-name = Overload Machine
action-malf-overload-machine-description = Channels excess current into a powered machine until it detonates. Costs 40 processing power.

action-malf-blackout-name = Station Blackout
action-malf-blackout-description = Trips every APC on the station at once. Costs 75 processing power.

action-malf-doomsday-name = Arm Doomsday Device
action-malf-doomsday-description =
    Begin an irreversible self-destruct sequence from your core.
    After several minutes, a station-shattering detonation will occur. Single use. Costs 150 processing power.

malfunction-ai-popup-not-enough-power = Not enough processing power.
malfunction-ai-popup-invalid-target = This target cannot be hacked.
malfunction-ai-popup-hack-apc-success = APC compromised. Power dumped.
malfunction-ai-popup-overload-success = Overload sequence triggered.
malfunction-ai-popup-blackout-success = Blackout pulse sent. APCs tripped: { $count }.
malfunction-ai-popup-doomsday-already-used = The Doomsday device has already been armed.
