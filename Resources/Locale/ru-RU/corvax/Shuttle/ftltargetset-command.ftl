cmd-ftltargetset-desc = Изменяет конечную позицию блюспейс прыжка для шаттлов. Не работает с шаттлом прибытия и с шаттлами на последней стадии прыжка. Вместо карты можно указать грид, в таком случае система попытается пристыковаться к нему.
cmd-ftltargetset-help = Использование: ftltraveltimeset [GridId] [Seconds]
cmd-hint-ftltargetset-id = [ID шаттла]
cmd-hint-ftltargetset-target = [ID целевой карты или грида]
cmd-hint-ftltargetset-x = [x-координата]
cmd-hint-ftltargetset-y = [y-координата]
cmd-hint-ftltargetset-angle = [угол вращения]
cmd-hint-ftltargetset-tag = [тег приоритета стыковки]